# ============================================================
# OZK TOBACCO — إعدادات المزامنة
# انسخ هذا الملف إلى tools\.env وعبّئ القيم
# ============================================================

# Supabase — من Dashboard → Settings → API
SUPABASE_URL=https://dyxbirfpxeocqffnfdeb.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key من Supabase

# الأمين SQL — كلمة سر المستخدم sa
AMEEN_SQL_WRITE_CONNECTION_STRING=Server=localhost;Database=mt000;User Id=sa;Password=YOUR_PASSWORD;

# قوائم الأسعار في الأمين (اختياري — القيم الافتراضية مأخوذة من قاعدة mt000 الفعلية)
# جملة الجملة (المبيعات/الطلبيات) و كروزات مركز (مبيعات المركز = المفرق)
# AMEEN_JUMLA_PRICELIST_GUID=41459845-f84b-4146-b3ec-8299b400792e
# AMEEN_RETAIL_PRICELIST_GUID=938cd3b0-75fd-4533-bad8-0fe42e6f7215
